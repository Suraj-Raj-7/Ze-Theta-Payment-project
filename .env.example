# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
#
# WHAT IS THIS FILE?
# This is a template showing what environment variables this project needs.
# It contains FAKE placeholder values — not real passwords.
#
# HOW TO USE IT:
# 1. Copy this file and name the copy exactly:  .env
# 2. Replace the placeholder values with your real values
# 3. Never share your .env file with anyone — it contains real passwords
#
# WHY DO WE USE ENVIRONMENT VARIABLES?
# Because putting passwords directly in code is dangerous.
# If your code goes to GitHub, your passwords go with it — and anyone can see them.
# Environment variables keep secrets OUT of your code.
#
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE CONNECTION
# -----------------------------------------------------------------------------
#
# This tells your app WHERE your PostgreSQL database is and how to log into it.
#
# Format breakdown:
#   postgresql://  ← the type of database
#   username       ← your PostgreSQL username
#   :password      ← your PostgreSQL password
#   @localhost     ← where the database is running (localhost = your own computer)
#   :5432          ← the port PostgreSQL listens on (5432 is always the default)
#   /payflow_db    ← the name of the specific database inside PostgreSQL
#
# For LOCAL development (running on your own machine):
DATABASE_URL=postgresql://username:password@localhost:5432/payflow_db
#
# For DOCKER (when running with docker-compose up):
# Docker uses "postgres" as the hostname instead of "localhost"
# because inside Docker, containers talk to each other by their service name
# DATABASE_URL=postgresql://payflow_user:payflow_pass@postgres:5432/payflow_db


# -----------------------------------------------------------------------------
# SECRET KEY
# -----------------------------------------------------------------------------
#
# This is used for cryptographic operations — specifically for verifying
# that incoming webhooks (payment notifications from gateways) are genuine
# and haven't been tampered with.
#
# Think of it like a wax seal on a letter — if the seal is broken, the letter
# was tampered with. The secret key is what creates that seal.
#
# In production (real live system):
#   - This should be a long, completely random string (at least 32 characters)
#   - Generated once and never changed (changing it would break all existing signatures)
#   - Never shared with anyone
#
# For development/testing, any string works:
SECRET_KEY=your-secret-key-here-make-it-long-and-random


# -----------------------------------------------------------------------------
# DEBUG MODE
# -----------------------------------------------------------------------------
#
# When DEBUG is True, your app shows detailed error messages if something
# goes wrong — helpful when you're developing and need to see what broke.
#
# When DEBUG is False, errors show a generic message instead — important
# in production because detailed error messages can reveal security information
# to attackers.
#
# Rule of thumb:
#   - True  → use during development on your own computer
#   - False → use in production (live system, Docker deployment)
#
DEBUG=True


# -----------------------------------------------------------------------------
# NOTES FOR DIFFERENT ENVIRONMENTS
# -----------------------------------------------------------------------------
#
# RUNNING LOCALLY (your own machine):
#   1. Copy this file to .env
#   2. Make sure PostgreSQL is running
#   3. Create a database called payflow_db in PostgreSQL
#   4. Fill in your PostgreSQL username and password above
#   5. Run: alembic upgrade head   (creates all tables)
#   6. Run: uvicorn app.main:app --reload
#
# RUNNING WITH DOCKER (recommended):
#   Docker Compose sets environment variables automatically — you don't
#   even need a .env file. The values are defined in docker-compose.yml.
#   Just run: docker-compose up
#
# =============================================================================
